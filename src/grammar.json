{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "blink",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_statement"
      }
    },
    "_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_expression"
        }
      ]
    },
    "_expression": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "integer_literal"
        },
        {
          "type": "SYMBOL",
          "name": "float_literal"
        },
        {
          "type": "SYMBOL",
          "name": "string_literal"
        },
        {
          "type": "SYMBOL",
          "name": "boolean_literal"
        }
      ]
    },
    "integer_literal": {
      "type": "PATTERN",
      "value": "[0-9]+"
    },
    "float_literal": {
      "type": "PATTERN",
      "value": "[0-9]+\\.[0-9]+"
    },
    "boolean_literal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "true"
        },
        {
          "type": "STRING",
          "value": "false"
        }
      ]
    },
    "string_literal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_basic_string"
        },
        {
          "type": "SYMBOL",
          "name": "_extended_string_1"
        },
        {
          "type": "SYMBOL",
          "name": "_extended_string_2"
        },
        {
          "type": "SYMBOL",
          "name": "_extended_string_3"
        }
      ]
    },
    "_basic_string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\""
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_string_content"
              },
              {
                "type": "SYMBOL",
                "name": "escape_sequence"
              },
              {
                "type": "SYMBOL",
                "name": "string_interpolation"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "_extended_string_1": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#\""
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_extended_string_content_1"
              },
              {
                "type": "SYMBOL",
                "name": "string_interpolation"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "\"#"
        }
      ]
    },
    "_extended_string_2": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "##\""
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_extended_string_content_2"
              },
              {
                "type": "SYMBOL",
                "name": "string_interpolation"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "\"##"
        }
      ]
    },
    "_extended_string_3": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "###\""
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_extended_string_content_3"
              },
              {
                "type": "SYMBOL",
                "name": "string_interpolation"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "\"###"
        }
      ]
    },
    "_string_content": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "[^\"\\\\{]+"
        }
      }
    },
    "_extended_string_content_1": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^{\"]+"
      }
    },
    "_extended_string_content_2": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^{\"]+"
      }
    },
    "_extended_string_content_3": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^{\"]+"
      }
    },
    "escape_sequence": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\\"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "n"
              },
              {
                "type": "STRING",
                "value": "r"
              },
              {
                "type": "STRING",
                "value": "t"
              },
              {
                "type": "STRING",
                "value": "\\"
              },
              {
                "type": "STRING",
                "value": "\""
              },
              {
                "type": "STRING",
                "value": "{"
              }
            ]
          }
        ]
      }
    },
    "string_interpolation": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SYMBOL",
          "name": "_expression"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "doc_comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "///"
          },
          {
            "type": "PATTERN",
            "value": ".*"
          }
        ]
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "//"
          },
          {
            "type": "PATTERN",
            "value": ".*"
          }
        ]
      }
    }
  },
  "extras": [
    {
      "type": "SYMBOL",
      "name": "comment"
    },
    {
      "type": "SYMBOL",
      "name": "doc_comment"
    },
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}